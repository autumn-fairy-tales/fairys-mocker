{
  "name": "root",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "-----": "============================cli=============================",
    "start:cli": "npm run-script start --workspace @fairys/mocker-cli",
    "watch:cli": "npm run-script watch --workspace @fairys/mocker-cli",
    "build:cli": "npm run-script build --workspace @fairys/mocker-cli",
    "----": "============================ui=============================",
    "start:ui": "npm run-script dev --workspace @fairys/mocker-ui",
    "build:ui": "npm run-script build --workspace @fairys/mocker-ui",
    "build:ui2": "npm run-script build2 --workspace @fairys/mocker-ui",
    "------": "============================create-mock-data=============================",
    "watch:create": "npm run-script watch --workspace @fairys/create-mock-data",
    "build:create": "npm run-script build --workspace @fairys/create-mock-data",
    "-------": "============================docs=============================",
    "build:docs": "npm run-script build --workspace docs",
    "docs": "npm run-script dev --workspace docs",
    "build:all": "npm run build:create && npm run build:cli && npm run build:ui && npm run build:docs",
    "build:all2": "npm run build:create && npm run build:cli && npm run build:ui2 && npm run build:docs",
    "version": "lerna version --force-publish=* --no-changelog --no-git-tag-version --no-push",
    "prettier": "prettier --write \"**/*.{js,jsx,tsx,ts,less,md,json}\""
  },
  "dependencies": {
    "@carefrees/rslib": "~0.1.2",
    "husky": "~9.1.7",
    "lerna": "~8.2.3",
    "lint-staged": "~16.1.4",
    "mockjs": "^1.1.0",
    "prettier": "~2.7.0",
    "pretty-quick": "~4.2.2",
    "typescript": "~6.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,tsx,ts,less,md,json}": "prettier --write"
  },
  "workspaces": [
    "examples/*",
    "packages/*",
    "docs"
  ]
}