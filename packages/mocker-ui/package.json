{
  "name": "@fairys/mocker-ui",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "copy": "mkdir -p ../mocker-cli/public/_fairys_mocker && cp -rf dist/* ../mocker-cli/public/_fairys_mocker/",
    "build:demo": "rsbuild build --config rsbuild.config.demo.ts",
    "build": "rsbuild build && npm run build:demo && npm run copy",
    "dev": "rsbuild dev --open",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "@carefrees/valtio": "^0.0.16",
    "@fairys/create-mock-data": "^0.0.5",
    "@uiw/react-textarea-code-editor": "~3.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.7.1",
    "@rsbuild/plugin-react": "^1.4.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mockjs": "^1.0.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
