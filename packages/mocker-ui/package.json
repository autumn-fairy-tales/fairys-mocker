{
  "name": "@fairys/mocker-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy": "mkdir -p ../mocker-cli/public/ui && cp -rf dist/ $_",
    "build:demo": "rsbuild build --config rsbuild.config.demo.ts",
    "build": "rsbuild build && npm run build:demo",
    "build2": "rsbuild build && npm run build:demo && npm run copy",
    "dev": "rsbuild dev --open",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@fairys/create-mock-data": "^0.0.0",
    "@carefrees/valtio": "^0.0.16"
  },
  "devDependencies": {
    "@types/mockjs": "^1.0.10",
    "@rsbuild/core": "^1.7.1",
    "@rsbuild/plugin-react": "^1.4.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}